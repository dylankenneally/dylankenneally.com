<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>{{ site.title }} | Software Engineer</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{{ site.description }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Fraunces:opsz,wght@9..144,600;9..144,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/styles.css">
  </head>
  <body>
    <div class="page-shell">
      <header class="hero">
        <nav class="topbar" aria-label="Primary">
          <a class="brand" href="#top">{{ site.title }}</a>
          <div class="topbar-links">
            <a href="#experience">Experience</a>
            <a href="#stack">Stack</a>
            <a href="#contact">Contact</a>
          </div>
        </nav>

        <div class="hero-grid" id="top">
          <section class="hero-copy">
            <p class="eyebrow">Melbourne software engineer</p>
            <h1>Available for hire, with a soft spot for thoughtful products and strong engineering teams.</h1>
            <p class="lede">{{ site.intro }}</p>
            <p class="availability">{{ site.availability }}</p>

            <div class="hero-actions">
              <a class="button button-primary" href="mailto:{{ site.email }}">Start a conversation</a>
              <a class="button button-secondary" href="{{ site.cvHref }}">Download CV</a>
            </div>

            <ul class="quick-notes" aria-label="Hiring notes">
              {% for note in site.hiringNotes %}
                <li>{{ note }}</li>
              {% endfor %}
            </ul>
          </section>

          <aside class="hero-card">
            <p class="card-kicker">Working style</p>
            <p class="card-copy">{{ site.summary }}</p>

            <div class="stat-grid">
              {% for stat in site.stats %}
                <article class="stat">
                  <strong>{{ stat.value }}</strong>
                  <span>{{ stat.label }}</span>
                </article>
              {% endfor %}
            </div>
          </aside>
        </div>
      </header>

      <main>
        <section class="panel panel-highlight">
          <div class="section-heading">
            <p class="eyebrow">What I am looking for</p>
            <h2>The short version</h2>
          </div>

          <div class="highlight-grid">
            {% for item in site.highlights %}
              <article class="highlight-card">
                <p class="eyebrow">{{ item.eyebrow }}</p>
                <h3>{{ item.title }}</h3>
                <p>{{ item.body }}</p>
              </article>
            {% endfor %}
          </div>
        </section>

        <section class="panel panel-focus">
          <div class="section-heading">
            <p class="eyebrow">How I can help</p>
            <h2>Strongest when the work spans product, code and delivery.</h2>
          </div>

          <div class="focus-layout">
            <ul class="focus-list">
              {% for area in site.focusAreas %}
                <li>{{ area }}</li>
              {% endfor %}
            </ul>

            <div class="note-card">
              <p>
                My background includes desktop engineering, real-time simulation, distributed systems,
                front-end architecture, cloud delivery and mobile product work. The common thread is
                building things that need to feel dependable in the hands of real users.
              </p>
            </div>
          </div>
        </section>

        <section class="panel" id="experience">
          <div class="section-heading">
            <p class="eyebrow">Selected experience</p>
            <h2>A long track record, still very hands-on.</h2>
          </div>

          <div class="timeline">
            {% for item in site.experience %}
              <article class="timeline-item">
                <div class="timeline-meta">
                  <p>{{ item.period }}</p>
                </div>
                <div class="timeline-content">
                  <h3>{{ item.role }} <span>@ {{ item.company }}</span></h3>
                  <p>{{ item.summary }}</p>
                  <ul>
                    {% for bullet in item.bullets %}
                      <li>{{ bullet }}</li>
                    {% endfor %}
                  </ul>
                </div>
              </article>
            {% endfor %}
          </div>
        </section>

        <section class="panel panel-stack" id="stack">
          <div class="section-heading">
            <p class="eyebrow">Preferred stack</p>
            <h2>Broad experience, current energy around modern JavaScript and cloud delivery.</h2>
          </div>

          <div class="chip-list" aria-label="Technology stack">
            {% for item in site.stack %}
              <span class="chip">{{ item }}</span>
            {% endfor %}
          </div>
        </section>

        <section class="panel panel-personal">
          <div class="section-heading">
            <p class="eyebrow">A bit more human</p>
            <h2>Professional, but not allergic to personality.</h2>
          </div>

          <div class="personal-grid">
            {% for item in site.personal %}
              <p>{{ item }}</p>
            {% endfor %}
          </div>
        </section>
      </main>

      <footer class="panel footer-panel" id="contact">
        <div class="section-heading">
          <p class="eyebrow">Get in touch</p>
          <h2>If you have a Melbourne role, a contract brief, or a team that could use an experienced pair of hands, say hello.</h2>
        </div>

        <div class="footer-layout">
          <div>
            <p class="footer-location">{{ site.location }}</p>
            <p class="footer-phone">{{ site.phone }}</p>
          </div>

          <ul class="contact-list">
            {% for link in site.links %}
              <li>
                <span>{{ link.label }}</span>
                <a href="{{ link.href }}">{{ link.text }}</a>
              </li>
            {% endfor %}
          </ul>
        </div>
      </footer>
    </div>
  </body>
</html>
